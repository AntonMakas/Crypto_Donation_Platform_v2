# ═══════════════════════════════════════════════════════════════
#  JarFund Frontend — Environment Variables
#  Copy to .env.local (Vite reads this automatically in dev)
#  VITE_ prefix is required for exposure to the browser bundle
# ═══════════════════════════════════════════════════════════════

# ── Backend API ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Blockchain ───────────────────────────────────────────────────
# WalletConnect Project ID — get from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Deployed JarFund contract address (matches backend .env)
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Chain IDs: Amoy=80002, Polygon=137, Hardhat=31337
VITE_CHAIN_ID=80002
VITE_CHAIN_NAME=amoy

# Block explorer base URL (no trailing slash)
VITE_EXPLORER_URL=https://amoy.polygonscan.com

# Polygon Amoy RPC (public endpoint, fine for read-only frontend calls)
VITE_RPC_URL=https://rpc-amoy.polygon.technology

# ── App ──────────────────────────────────────────────────────────
VITE_APP_NAME=JarFund
VITE_APP_DESCRIPTION=Secure Crypto Donation Platform

# Set to "true" to show debug info (tx receipts, raw errors, etc.)
VITE_DEBUG=false
