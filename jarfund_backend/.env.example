# ═══════════════════════════════════════════════════════════════════
#  JarFund Backend — Environment Variables
#
#  Copy this file to .env and fill in your values.
#  ⚠️  NEVER commit .env to git. It's in .gitignore.
# ═══════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────
#  DJANGO CORE
# ──────────────────────────────────────────────────────────────────

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-generate-a-real-one

# Set to True ONLY for local development
DEBUG=True

# Comma-separated list of allowed hostnames
# Dev:        localhost,127.0.0.1
# Production: api.jarfund.io,jarfund-backend.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1


# ──────────────────────────────────────────────────────────────────
#  DATABASE (PostgreSQL)
# ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://jarfund:jarfund_pass@localhost:5432/jarfund_db

# Connection pool keep-alive (seconds)
DB_CONN_MAX_AGE=60


# ──────────────────────────────────────────────────────────────────
#  REDIS (Celery broker + Cache)
# ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ──────────────────────────────────────────────────────────────────
#  CORS — Frontend origins allowed to call the API
# ──────────────────────────────────────────────────────────────────
# Dev:  http://localhost:5173,http://127.0.0.1:5173
# Prod: https://jarfund.io,https://www.jarfund.io
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ──────────────────────────────────────────────────────────────────
#  BLOCKCHAIN
# ──────────────────────────────────────────────────────────────────
# RPC endpoint — get from Alchemy: https://alchemy.com
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployed JarFund contract address (fill after deployment)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Chain IDs:  Amoy=80002, Polygon Mainnet=137, Hardhat Local=31337
CHAIN_ID=80002

# "amoy" | "polygon" | "hardhat"
NETWORK_NAME=amoy

# Block confirmations required before marking donation as verified
REQUIRED_CONFIRMATIONS=3

# Block explorer base URL (no trailing slash)
EXPLORER_URL=https://amoy.polygonscan.com


# ──────────────────────────────────────────────────────────────────
#  ADMIN
# ──────────────────────────────────────────────────────────────────
# Obscure the admin URL in production
ADMIN_URL=admin-jarfund-secure/


# ──────────────────────────────────────────────────────────────────
#  EMAIL (optional — only needed for production)
# ──────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@jarfund.io


# ──────────────────────────────────────────────────────────────────
#  SENTRY (optional — error tracking in production)
# ──────────────────────────────────────────────────────────────────
SENTRY_DSN=
